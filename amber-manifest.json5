{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/neilarphy/tau2-purple-agent:latest",
    entrypoint: ["uv", "run", "src/server.py", "--host", "0.0.0.0", "--port", "9009"],
    env: {
      AGENT_MODEL: "${config.agent_llm}",
      BOTHUB_API_KEY: "${config.bothub_api_key}",
      BOTHUB_BASE_URL: "${config.bothub_base_url}",
      LOG_LEVEL: "INFO",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 9009 }
      ]
    }
  },
  config_schema: {
    type: "object",
    properties: {
      agent_llm: { type: "string", default: "gpt-4o" },
      bothub_api_key: { type: "string", secret: true },
      bothub_base_url: { type: "string", default: "https://bothub.chat/api/v2/openai/v1" },
    },
    required: ["bothub_api_key"],
    additionalProperties: false,
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" }
  },
  exports: {
    a2a: "a2a"
  }
}
